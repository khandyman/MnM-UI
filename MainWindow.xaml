<Window x:Class="MnM_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MnM_UI"
        mc:Ignorable="d"
        Title="MnM-UI" Height="600" Width="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        BorderBrush="WhiteSmoke"
        FontFamily="Comprehension-Dark" 
        MouseDown="Window_MouseDown">

    <DockPanel>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30*" />
                <RowDefinition Height="60*" />
                <RowDefinition Height="10*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            
            <Grid.Background>
                <ImageBrush ImageSource="/images/background.PNG"
                            TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,100,100"
                            />
            </Grid.Background>
            

            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Copy UI -->
                <Border Grid.Column="0" Margin="0,0,5,0" BorderBrush="WhiteSmoke" BorderThickness="1">
                    <DockPanel Margin="5,0,5,0">
                        <Label DockPanel.Dock="Top" FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke" HorizontalAlignment="Center">Copy UI</Label>
                        <Label DockPanel.Dock="Top" Margin="10,0,0,0" FontSize="14" Foreground="WhiteSmoke">UI Template Folder</Label>
                        <TextBox DockPanel.Dock="Top" x:Name="txtTemplatePath" Margin="5,6,5,6" Padding="5" FontSize="16" Background="LightGray" MouseDoubleClick="ChangeTemplate_Click">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change" Click="ChangeTemplate_Click" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                        <Button DockPanel.Dock="Bottom" x:Name="btnCopy" Margin="5,7,5,7" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" Click="ButtonCopy_Click">Copy
                            <Button.Background>
                                <ImageBrush ImageSource="/images/button.PNG"
                                            TileMode="Tile"
                                            ViewportUnits="Absolute"
                                            Viewport="0,0,100,100"
                                            />
                            </Button.Background>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Merge Journals -->
                <Border Grid.Column="1" Margin="5,0,0,0" BorderBrush="WhiteSmoke" BorderThickness="1">
                    <DockPanel Margin="5,0,5,0">
                        <Label DockPanel.Dock="Top" FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke" HorizontalAlignment="Center">Merge Journals</Label>
                        <Label DockPanel.Dock="Top" Margin="10,0,0,0" FontSize="14" Foreground="WhiteSmoke">Journal Backup Folder</Label>
                        <TextBox DockPanel.Dock="Top" x:Name="txtJournalPath" Margin="5,6,5,6" Padding="5" FontSize="16" Background="LightGray" MouseDoubleClick="ChangeJournal_Click">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change" Click="ChangeJournal_Click" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                        <Button DockPanel.Dock="Bottom" x:Name="btnMerge" Margin="5,7,5,7" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" BorderThickness="1" Click="ButtonMerge_Click">Merge
                            <Button.Background>
                                <ImageBrush ImageSource="/images/button.PNG"
                                            TileMode="Tile"
                                            ViewportUnits="Absolute"
                                            Viewport="0,0,100,100"
                                            />
                            </Button.Background>
                        </Button>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Program Output -->
            <Border Grid.Row="1" Margin="5" BorderBrush="WhiteSmoke" BorderThickness="1">
                <DockPanel Grid.Row="1" Margin="5" LastChildFill="True">
                    <Label FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke"  DockPanel.Dock="Top">Program Output</Label>
                    <ListBox Background="LightGray" Margin="5" FontSize="16" DockPanel.Dock="Top" x:Name="lstOutput" />
                </DockPanel>
            </Border>

            <Button Grid.Row="2" Margin="5" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" Width="150" HorizontalAlignment="Center" Click="ExitCommand_Click">Exit
                <Button.Background>
                    <ImageBrush ImageSource="/images/button.PNG"
                                TileMode="Tile"
                                ViewportUnits="Absolute"
                                Viewport="0,0,100,100"
                                />
                </Button.Background>
            
            </Button>
        </Grid>
        
    </DockPanel>
    
    
</Window>
