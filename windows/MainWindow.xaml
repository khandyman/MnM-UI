<Window x:Class="MnM_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MnM_UI"
        mc:Ignorable="d"
        Title="MnM-UI - Monsters and Memories UI Management Tool" Height="700" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        BorderBrush="WhiteSmoke"
        FontFamily="./fonts/#Crimson Text Regular (TrueType)"
        MouseDown="Window_MouseDown">

    <DockPanel>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*" />
                <RowDefinition Height="30*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="10*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            
            <Grid.Background>
                <ImageBrush ImageSource="/images/background.PNG"
                            TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,100,100"
                            />
            </Grid.Background>

            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" FontSize="24" Foreground="WhiteSmoke" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">Monsters and Memories UI Management Tool</Label>

            <Grid Margin="5" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                

                <!-- Copy UI -->
                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,5,0" BorderBrush="WhiteSmoke" BorderThickness="1">
                    <DockPanel Margin="5,0,5,0">
                        <Label DockPanel.Dock="Top" FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke" HorizontalAlignment="Center">Copy UI</Label>
                        <Label DockPanel.Dock="Top" Margin="10,0,0,0" FontWeight="Bold" FontSize="14" Foreground="WhiteSmoke">UI Template Folder</Label>
                        <TextBox DockPanel.Dock="Top" x:Name="txtTemplatePath" x:FieldModifier="public" Margin="5,6,5,6" Padding="5" FontSize="16" FontWeight="Bold"
                                 MouseDoubleClick="ChangeTemplate_Click" ToolTip="Select a &quot;Template&quot; Directory with both windows.json and chats.json inside">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change" Click="ChangeTemplate_Click" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                            <TextBox.Background>
                                <ImageBrush ImageSource="/images/control.png"
                                TileMode="Tile"
                                ViewportUnits="Absolute"
                                Viewport="0,0,100,100"
                                />
                            </TextBox.Background>
                        </TextBox>
                        <CheckBox DockPanel.Dock="Top" x:Name="chkCopyCharacter" Margin="5,5,5,5" FontSize="14" FontWeight="Bold" Foreground="WhiteSmoke" Click="CopyCharacter_Click">Copy Existing Character?</CheckBox>
                        <Button DockPanel.Dock="Bottom" x:Name="btnCopy" Margin="5,7,5,7" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" Click="ButtonCopy_Click">Copy
                            <Button.Background>
                                <ImageBrush ImageSource="/images/button.PNG"
                                            TileMode="Tile"
                                            ViewportUnits="Absolute"
                                            Viewport="0,0,100,100"
                                            />
                            </Button.Background>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Merge Journals -->
                <Border Grid.Row="1" Grid.Column="1" Margin="5,0,0,0" BorderBrush="WhiteSmoke" BorderThickness="1">
                    <DockPanel Margin="5,0,5,0">
                        <Label DockPanel.Dock="Top" FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke" HorizontalAlignment="Center">Merge Journals</Label>
                        <Label DockPanel.Dock="Top" Margin="10,0,0,0" FontWeight="Bold" FontSize="14" Foreground="WhiteSmoke">Journal Backup Folder</Label>
                        <TextBox DockPanel.Dock="Top" x:Name="txtJournalPath" x:FieldModifier="public" Margin="5,6,5,6" Padding="5" FontSize="16" FontWeight="Bold"
                                 MouseDoubleClick="ChangeJournal_Click" ToolTip="Select a Monsters and Memories directory you want to merge journals to/from">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change" Click="ChangeJournal_Click" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                            <TextBox.Background>
                                <ImageBrush ImageSource="/images/control.png"
                                TileMode="Tile"
                                ViewportUnits="Absolute"
                                Viewport="0,0,100,100"
                                />
                            </TextBox.Background>
                        </TextBox>
                        <CheckBox DockPanel.Dock="Top" x:Name="chkNewBackup" Margin="5,5,5,5" FontSize="14" FontWeight="Bold" Foreground="WhiteSmoke" Click="NewBackup_Click">Create New Backup?</CheckBox>
                        <Button DockPanel.Dock="Bottom" x:Name="btnMerge" Margin="5,7,5,7" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" BorderThickness="1" Click="ButtonMerge_Click">Merge
                            <Button.Background>
                                <ImageBrush ImageSource="/images/button.PNG"
                                            TileMode="Tile"
                                            ViewportUnits="Absolute"
                                            Viewport="0,0,100,100"
                                            />
                            </Button.Background>
                        </Button>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Program Output -->
            <Border Grid.Row="2" Margin="5" BorderBrush="WhiteSmoke" BorderThickness="1">
                <DockPanel Grid.Row="1" Margin="5" LastChildFill="True">
                    <Label FontWeight="Bold" FontSize="16" Foreground="WhiteSmoke"  DockPanel.Dock="Top">Program Output</Label>
                    <ListBox Margin="5" FontSize="16" FontWeight="Bold" DockPanel.Dock="Top" x:Name="lstOutput">
                        <ListBox.Background>
                            <ImageBrush ImageSource="/images/control.png"
                            TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,100,100"
                            />
                        </ListBox.Background>
                    </ListBox>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Margin="5" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" Width="150" 
                        Click="HelpCommand_Click">Help
                    <Button.Background>
                        <ImageBrush ImageSource="/images/button.PNG"
                        TileMode="Tile"
                        ViewportUnits="Absolute"
                        Viewport="0,0,100,100"
                        />
                    </Button.Background>
                </Button>

                <Button Margin="5" Padding="5" FontSize="20" FontWeight="ExtraBold" Foreground="WhiteSmoke" Width="150" Click="ExitCommand_Click">Exit
                    <Button.Background>
                        <ImageBrush ImageSource="/images/button.PNG"
                        TileMode="Tile"
                        ViewportUnits="Absolute"
                        Viewport="0,0,100,100"
                        />
                    </Button.Background>
                </Button>
            </StackPanel>
        </Grid>
        
    </DockPanel>
    
    
</Window>
